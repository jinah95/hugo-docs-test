[{"id":0,"href":"/docs/software/","title":"소프트웨어 가이드","section":"나의 무적 가이드북","content":"🖥️ 소프트웨어 설치 및 관리#\r이 섹션에서는 서비스 운영을 위한 소프트웨어의 필수 요구 사양과 단계별 설치 가이드를 제공합니다.\n제공하는 문서#\r최소 사양 가이드: 원활한 구동을 위한 하드웨어 및 소프트웨어 요구사항을 확인합니다. 설치 가이드: 단계별 스크립트 및 환경 설정 방법을 안내합니다. 💡 왼쪽 사이드바 메뉴를 펼치면 하위 문서(최소 사양, 설치 가이드)로 바로 이동할 수 있습니다.\n"},{"id":1,"href":"/docs/","title":"나의 무적 가이드북","section":"가이드 문서","content":"환영합니다! 👋#\r오측 메뉴와 Decap CMS를 활용해 마케터와 함께 멋진 문서를 채워보세요.\n"},{"id":2,"href":"/docs/software/%EB%B0%98%EA%B0%91%EC%8A%B5%EB%8B%88%EB%8B%A4-%EC%86%8C%ED%94%84%ED%8A%B8%EC%9B%A8%EC%96%B4/","title":"반갑습니다 소프트웨어","section":"소프트웨어 가이드","content":"반갑습니다 소프트웨어\n"},{"id":3,"href":"/docs/software/sofrtware/","title":"sofrtware","section":"소프트웨어 가이드","content":"software\u0026hellip;.\n"},{"id":4,"href":"/docs/software/%EC%95%88%EB%85%95%ED%95%98%EC%84%B8%EC%9A%9422/","title":"안녕하세요22","section":"소프트웨어 가이드","content":"안녕하세요안녕하세요안녕하세요안녕하세요안녕하세요\n"},{"id":5,"href":"/docs/%EC%95%88%EB%85%95%ED%95%98%EC%84%B8%EC%9A%94/","title":"안녕하세요","section":"나의 무적 가이드북","content":"ㅎㅈㄷㅎㅈㄷㅎㅈㄷㅎ\n"},{"id":6,"href":"/docs/software/%EC%95%88%EB%85%95%ED%95%98%EC%84%B8%EC%9A%94/","title":"안녕하세요","section":"소프트웨어 가이드","content":"경로를 지정했나요?\n"},{"id":7,"href":"/posts/%EC%B2%AB-%ED%8F%AC%EC%8A%A4%ED%8C%85-%EB%91%90%EA%B7%BC%EB%91%90%EA%B7%BC/","title":"첫 포스팅 두근두근","section":"Blog Posts","content":"왜 이미지 액박이\u0026hellip;\n"},{"id":8,"href":"/posts/%EB%B0%98%EA%B0%91%EC%8A%B5%EB%8B%88%EB%8B%A4/","title":"반갑습니다.","section":"Blog Posts","content":"해당 내용들이 posts 목록에 올라갈까요???\n"},{"id":9,"href":"/posts/%EC%95%88%EB%85%95%ED%95%98%EC%84%B8%EC%9A%94/","title":"안녕하세요","section":"Blog Posts","content":"ggggggwegweggwe\n"}]